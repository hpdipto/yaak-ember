        "dev": "yaak plugin dev"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.14"
    },
    "dependencies": {
        "@yaakapp/api": "^0.7.0"
    }

{
    "name": "@hpdipto/ember-theme",
    "displayName": "Ember Theme",
    "description": "Ember Theme for Yaak",
    "version": "0.0.1",
    "main": "build/index.js",
    "license": "MIT",
    "author": "hpdipto",
    "keywords": [
        "yaak-plugin",
        "theme"
    ],
    "yaak": {
        "title": "Ember Theme",
